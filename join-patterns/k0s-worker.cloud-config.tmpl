#cloud-config
ssh_authorized_keys:
{{- range .sshAuthorizedKeys }}
  - {{ . }}
{{- end }}
# k0s-worker join pattern: bring up the WireGuard tunnel, gate on the
# cluster's API VIP becoming reachable through it, then join as a plain
# k0s worker using a pre-minted join token. This is CAPA's own
# Machine.spec.bootstrap.dataSecretName content -- no bootstrap
# provider involved. That's deliberate, not a shortcut: a bootstrap
# provider's whole value is generating this content FOR you from a
# CAPI-managed control plane, and there isn't one here (see
# ../README.md's "Why no k0smotron" section). Every value below comes
# from the render tool's input, not from any control-plane object.
write_files:
  # Not wg0.conf/wg-quick: wg-quick auto-installs a kernel route for
  # every AllowedIPs entry with no isolation at all -- the exact
  # unmitigated version of the incident that hit the on-prem side
  # (jarvis) before its own dialer got a route-table-isolation fix. The
  # same hardened Go dialer binary runs here instead (as a systemd
  # unit, listener role -- see wg-dialer.service below), inheriting
  # that isolation directly rather than reimplementing it. This file
  # never needs new PEERS added later: once this node has even one live
  # WireGuard relationship to any on-prem node, Calico's own BGP mesh
  # propagates routes to the rest of the on-prem cluster through that
  # one peer as a transit path, so a new on-prem node joining later
  # doesn't require this file to change. localAddress (this node's own
  # tunnel address) travels in this file too, not a flag -- see
  # cmd/dialer/main.go's peersFileDoc doc comment for why.
  #
  # This file is also read by a second, later-arriving consumer:
  # once this node joins as a real k8s worker, endpoint-controller's
  # ensureCloudDialerDaemonSet schedules a containerized copy of the
  # same dialer binary onto it (hostPath-mounting this same file
  # read-only) -- see that function's doc comment for why both this
  # systemd unit and that DaemonSet run forever, redundantly, rather
  # than one handing off to the other.
  - path: /etc/wg-dialer/peers.json
    permissions: '0600'
    content: |
      {{ .peersFileJSON }}
  - path: /etc/systemd/system/wg-dialer.service
    permissions: '0644'
    content: |
      [Unit]
      Description=wg-dialer (listener role)
      After=network-online.target
      Wants=network-online.target

      [Service]
      ExecStart=/usr/local/bin/wg-dialer \
        --iface=wg0 \
        --peers-file=/etc/wg-dialer/peers.json \
        --listen-port={{ .wireguardListenPort }} \
        --pod-cidrs={{ .podCIDRs }} \
        --service-cidrs={{ .serviceCIDRs }} \
        --keepalive-seconds=15 \
        --mtu=1420 \
        --poll-interval=30s
      Restart=always
      AmbientCapabilities=CAP_NET_ADMIN

      [Install]
      WantedBy=multi-user.target
  - path: /etc/k0s/join-token
    permissions: '0600'
    content: |
      {{ .joinToken }}
runcmd:
  # /usr/local/bin/wg-dialer is expected to already be present in the
  # image this cloud-init runs against (baked in at image-build time,
  # the same binary the on-prem DaemonSet's hostPath mount uses) -- no
  # apt install of wireguard-tools needed anymore; this binary talks
  # to the kernel's WireGuard interface directly via netlink/wgctrl,
  # same as the on-prem side always has.
  - systemctl enable --now wg-dialer.service
  - until ping -c1 -W2 {{ .apiVIP }} >/dev/null 2>&1; do sleep 2; done
  # Calico's IP_AUTODETECTION_METHOD/IP6_AUTODETECTION_METHOD on this
  # cluster are cidr= matches (see the cluster's calico-node DaemonSet
  # env), the same convention every on-prem node satisfies with a dummy
  # vip0 interface (confirmed via `ip -br addr show vip0` on jarvis:
  # 10.101.0.1/32 + fd8f:cf26:522a::1/128). Without an address in those
  # CIDRs on some interface, calico-node fails to start at all
  # ("failed to autodetect an IPv4 address") -- this isn't optional,
  # it's the same mechanism every other node already relies on.
  - ip link add vip0 type dummy
  - ip addr add {{ .nodeVIP4 }}/32 dev vip0
  - ip addr add {{ .nodeVIP6 }}/128 dev vip0
  - ip link set vip0 up
  - curl -sSLf https://get.k0s.sh | K0S_VERSION={{ .k0sVersion }} sh
  # k0s resolves node IPs by looking up the instance's own hostname, not
  # by inspecting interfaces -- on AWS that hostname only maps to the
  # private IPv4 in /etc/hosts, so a dual-stack cluster's kubelet fails
  # to start ("IP address lookup didn't return addresses for both
  # families") even when the interface genuinely has a real IPv6 GUA.
  # --node-ip bypasses that lookup with addresses fetched directly from
  # instance metadata instead. (IMDSv2, AWS-specific: a different
  # infrastructure provider's variant of this pattern would fetch its
  # own metadata service here instead.)
  - |
    IMDS_TOKEN=$(curl -sSf -X PUT "http://169.254.169.254/latest/api/token" -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
    NODE_IPV4=$(curl -sSf -H "X-aws-ec2-metadata-token: $IMDS_TOKEN" http://169.254.169.254/latest/meta-data/local-ipv4)
    NODE_IPV6=$(curl -sSf -H "X-aws-ec2-metadata-token: $IMDS_TOKEN" http://169.254.169.254/latest/meta-data/ipv6 || true)
    NODE_IP_ARG="--node-ip=$NODE_IPV4"
    [ -n "$NODE_IPV6" ] && NODE_IP_ARG="--node-ip=$NODE_IPV4,$NODE_IPV6"
    k0s install worker --token-file /etc/k0s/join-token --kubelet-extra-args="{{ .kubeletExtraArgs }} $NODE_IP_ARG"
  - k0s start
